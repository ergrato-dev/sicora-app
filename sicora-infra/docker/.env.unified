# =============================================================================
# SICORA - Configuración Unificada de Base de Datos
# =============================================================================
# FUENTE ÚNICA DE VERDAD para conexiones de base de datos
# Usado por: sicora-be-go, sicora-be-python, sicora-infra
# =============================================================================

# -----------------------------------------------------------------------------
# PostgreSQL - Configuración Principal
# -----------------------------------------------------------------------------
# Una sola base de datos con esquemas por servicio
POSTGRES_HOST=localhost
POSTGRES_PORT=5433
POSTGRES_DB=sicora_dev
POSTGRES_USER=sicora_user
POSTGRES_PASSWORD=sicora_password

# URL de conexión base (sin esquema específico)
# Go: postgres://sicora_user:sicora_password@localhost:5433/sicora_dev?sslmode=disable
# Python: postgresql+asyncpg://sicora_user:sicora_password@localhost:5433/sicora_dev

# -----------------------------------------------------------------------------
# Esquemas por Servicio (9 servicios implementados)
# -----------------------------------------------------------------------------
# Go: userservice, scheduleservice, attendanceservice, evalinservice,
#     kbservice, mevalservice, projectevalservice, apigateway
# Python: aiservice
USERSERVICE_SCHEMA=userservice
SCHEDULESERVICE_SCHEMA=scheduleservice
ATTENDANCESERVICE_SCHEMA=attendanceservice
EVALINSERVICE_SCHEMA=evalinservice
KBSERVICE_SCHEMA=kbservice
MEVALSERVICE_SCHEMA=mevalservice
AISERVICE_SCHEMA=aiservice
PROJECTEVALSERVICE_SCHEMA=projectevalservice
APIGATEWAY_SCHEMA=apigateway

# -----------------------------------------------------------------------------
# Redis - Configuración
# -----------------------------------------------------------------------------
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_URL=redis://localhost:6379

# -----------------------------------------------------------------------------
# MongoDB - Configuración
# -----------------------------------------------------------------------------
MONGODB_HOST=localhost
MONGODB_PORT=27017
MONGODB_DATABASE=sicora_nosql
MONGODB_USER=sicora_admin
MONGODB_PASSWORD=sicora_mongo_2024
MONGODB_URL=mongodb://sicora_admin:sicora_mongo_2024@localhost:27017/sicora_nosql?authSource=admin

# -----------------------------------------------------------------------------
# Seguridad
# -----------------------------------------------------------------------------
JWT_SECRET=sicora-dev-secret-key-change-in-production-2024
JWT_EXPIRATION_HOURS=24

# -----------------------------------------------------------------------------
# Entorno
# -----------------------------------------------------------------------------
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=info
