# Traefik Environment Variables
# Copy to .env and adjust values

# =============================================================================
# GENERAL
# =============================================================================
ENVIRONMENT=development
LOG_LEVEL=info

# =============================================================================
# TRAEFIK
# =============================================================================
# Email para Let's Encrypt (obligatorio en producción)
ACME_EMAIL=admin@sicora.dev

# Dashboard credentials (generado con: htpasswd -nb admin password)
# TRAEFIK_DASHBOARD_USER=admin
# TRAEFIK_DASHBOARD_PASSWORD=traefik

# =============================================================================
# DATABASE - PostgreSQL
# =============================================================================
POSTGRES_DB=sicora_dev
POSTGRES_USER=sicora_user
POSTGRES_PASSWORD=sicora_password_change_me

# =============================================================================
# DATABASE - MongoDB
# =============================================================================
MONGODB_ROOT_USER=sicora_admin
MONGODB_ROOT_PASSWORD=mongodb_password_change_me
MONGODB_DATABASE=sicora_nosql

# =============================================================================
# CACHE - Redis
# =============================================================================
REDIS_PASSWORD=

# =============================================================================
# SECURITY
# =============================================================================
JWT_SECRET=your-super-secret-jwt-key-change-in-production-min-32-chars
JWT_EXPIRATION=24h

# =============================================================================
# CORS (separados por coma)
# =============================================================================
# Desarrollo
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://app.localhost

# Producción (descomentar y ajustar)
# CORS_ORIGINS=https://sicora.dev,https://www.sicora.dev,https://app.sicora.dev

# =============================================================================
# RATE LIMITING
# =============================================================================
RATE_LIMIT=100

# =============================================================================
# MONITORING
# =============================================================================
GRAFANA_PASSWORD=admin_change_me
