# API Gateway Configuration
# Copy this file to .env and adjust values

# Server Configuration
PORT=8000
ENVIRONMENT=development
LOG_LEVEL=info

# JWT Configuration
JWT_SECRET=your-secret-key-change-in-production
JWT_EXPIRATION=24h

# CORS Configuration
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Rate Limiting
RATE_LIMIT=100

# Timeouts
READ_TIMEOUT=30s
WRITE_TIMEOUT=30s
IDLE_TIMEOUT=60s

# Backend Service URLs
USERSERVICE_URL=http://localhost:8001
SCHEDULESERVICE_URL=http://localhost:8002
ATTENDANCESERVICE_URL=http://localhost:8003
EVALINSERVICE_URL=http://localhost:8004
KBSERVICE_URL=http://localhost:8005
AISERVICE_URL=http://localhost:8006
PROJECTEVALSERVICE_URL=http://localhost:8007
MEVALSERVICE_URL=http://localhost:8008
